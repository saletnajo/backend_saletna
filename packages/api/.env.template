# Cash on Delivery (COD)
# Regions that offer COD, comma-separated region ids. Consumed by
# `npx medusa exec ./src/scripts/enable-cod.ts` (region enablement) and by
# checkout eligibility; leave empty to allow any region with an allowed
# currency.
COD_ALLOWED_REGION_IDS=
# Currencies COD accepts at checkout (comma-separated, default: jod).
COD_ALLOWED_CURRENCIES=
# Max cart total (in currency units, e.g. 500.000) eligible for COD; empty
# disables the cap.
COD_MAX_ORDER_VALUE_JOD=
# Block customers whose summed COD failure attempts reach this; 0 disables
# (default: 3).
COD_MAX_FAILED_ATTEMPTS_PER_CUSTOMER=
# Product tag values excluded from COD (comma-separated, case-insensitive).
COD_EXCLUDED_PRODUCT_TAGS=